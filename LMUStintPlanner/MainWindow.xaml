<Window x:Class="LMUStintPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="LMU Stint Planner"
        Height="930"
        Width="1560"
        MinHeight="820"
        MinWidth="1280"
        Background="#160A0C">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,16"
                Padding="22"
                Background="#2A1116"
                CornerRadius="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="#FFF5F5"
                               Text="Le Mans Ultimate Stint Planner" />
                    <TextBlock Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="#D3B5BA"
                               Text="Team-race planning with live stint updates, pit timing, tyre allocation, driver swaps, and real-world local time windows." />
                </StackPanel>

                <WrapPanel Grid.Column="1"
                           VerticalAlignment="Center">
                    <Button Margin="0,0,10,0"
                            Padding="16,10"
                            Background="#C44536"
                            Foreground="White"
                            BorderBrush="#C44536"
                            Command="{Binding GenerateStrategyCommand}"
                            Content="Generate Plan" />
                    <Button Padding="16,10"
                            Background="#7C2430"
                            Foreground="White"
                            BorderBrush="#7C2430"
                            Command="{Binding AddManualStintCommand}"
                            Content="Add Manual Stint" />
                </WrapPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#2A1116"
                    CornerRadius="16">
                <TabControl Background="#2A1116"
                            BorderThickness="0"
                            TabStripPlacement="Left">
                    <TabItem Header="Race">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Margin="8" Padding="18" Background="#2A1116" CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#FFF5F5" Text="Race Setup" />
                                    <CheckBox Margin="0,14,0,0"
                                              Foreground="#F2D7DA"
                                              IsChecked="{Binding AutoGeneratePlan, Mode=TwoWay}"
                                              Content="Auto-generate stint plan from current inputs" />

                                    <TextBlock Margin="0,14,0,0" Foreground="#D5B3B8" Text="Track" />
                                    <ComboBox Margin="0,6,0,0"
                                              Padding="8"
                                              Background="#F6E8EA"
                                              Foreground="#241316"
                                              BorderBrush="#7A2E39"
                                              ItemsSource="{Binding Tracks}"
                                              SelectedItem="{Binding SelectedTrack, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="DisplayName" />

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="Race Start" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding RaceStartText, UpdateSourceTrigger=PropertyChanged}" />

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Foreground="#D5B3B8" Text="Hours" />
                                            <TextBox Margin="0,6,0,0"
                                                     Padding="8"
                                                     Background="#F6E8EA"
                                                     Foreground="#241316"
                                                     BorderBrush="#7A2E39"
                                                     Text="{Binding RaceLengthHours, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                            <TextBlock Foreground="#D5B3B8" Text="Minutes" />
                                            <TextBox Margin="0,6,0,0"
                                                     Padding="8"
                                                     Background="#F6E8EA"
                                                     Foreground="#241316"
                                                     BorderBrush="#7A2E39"
                                                     Text="{Binding RaceLengthMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                            <TextBlock Foreground="#D5B3B8" Text="Race Time Zone" />
                                            <ComboBox Margin="0,6,0,0"
                                                      Padding="8"
                                                      Background="#F6E8EA"
                                                      Foreground="#241316"
                                                      BorderBrush="#7A2E39"
                                                      ItemsSource="{Binding TimeZones}"
                                                      SelectedValuePath="Id"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValue="{Binding RaceTimeZoneId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Foreground="#D5B3B8" Text="Full Refill Time (s)" />
                                            <TextBox Margin="0,6,0,0"
                                                     Padding="8"
                                                     Background="#F6E8EA"
                                                     Foreground="#241316"
                                                     BorderBrush="#7A2E39"
                                                     Text="{Binding FullRefillSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                            <TextBlock Foreground="#D5B3B8" Text="Tyre Change (s)" />
                                            <TextBox Margin="0,6,0,0"
                                                     Padding="8"
                                                     Background="#F6E8EA"
                                                     Foreground="#241316"
                                                     BorderBrush="#7A2E39"
                                                     Text="{Binding TyreChangeSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="Available Tyres" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding AvailableTyres, UpdateSourceTrigger=PropertyChanged}" />

                                    <Border Margin="0,14,0,0"
                                            Padding="14"
                                            Background="#F3E1E4"
                                            CornerRadius="12">
                                        <TextBlock Foreground="#2B181B"
                                                   Text="{Binding RaceStartSummary}"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Car">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Margin="8" Padding="18" Background="#2A1116" CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#FFF5F5" Text="Car And Pit" />

                                    <TextBlock Margin="0,14,0,0" Foreground="#D5B3B8" Text="Car Class" />
                                    <ComboBox Margin="0,6,0,0"
                                              Padding="8"
                                              Background="#F6E8EA"
                                              Foreground="#241316"
                                              BorderBrush="#7A2E39"
                                              ItemsSource="{Binding CarClasses}"
                                              SelectedItem="{Binding SelectedCarClass, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name" />

                                    <StackPanel Margin="0,12,0,0"
                                                Visibility="{Binding ShowFuelCapacity, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Foreground="#D5B3B8" Text="Fuel Capacity" />
                                        <TextBox Margin="0,6,0,0"
                                                 Padding="8"
                                                 Background="#F6E8EA"
                                                 Foreground="#241316"
                                                 BorderBrush="#7A2E39"
                                                 Text="{Binding FuelCapacity, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Margin="0,12,0,0"
                                                Visibility="{Binding ShowFuelPerLap, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Foreground="#D5B3B8" Text="Fuel Per Lap" />
                                        <TextBox Margin="0,6,0,0"
                                                 Padding="8"
                                                 Background="#F6E8EA"
                                                 Foreground="#241316"
                                                 BorderBrush="#7A2E39"
                                                 Text="{Binding FuelPerLap, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="VE Capacity" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding EnergyCapacity, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="Pit Lane Time (s)" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding PitLaneSeconds, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="Base Service Time (s)" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding BasePitSeconds, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="Default Repair Time (s)" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding DefaultRepairSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Weather">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Margin="8" Padding="18" Background="#2A1116" CornerRadius="16">
                                <StackPanel>
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#FFF5F5" Text="Rain Crossover" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#D5B3B8"
                                               Text="Use current dry pace, current wet pace, and stint fuel or laps remaining to judge whether the crossover point is here."
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,14,0,0" Foreground="#D5B3B8" Text="Current Dry Lap" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding CurrentDryLapTimeText, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="Current Wet Lap" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding CurrentWetLapTimeText, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="Laps Left On Stint" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding RemainingStintLaps, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Margin="0,12,0,0" Foreground="#D5B3B8" Text="Fuel Left On Stint" />
                                    <TextBox Margin="0,6,0,0"
                                             Padding="8"
                                             Background="#F6E8EA"
                                             Foreground="#241316"
                                             BorderBrush="#7A2E39"
                                             Text="{Binding RemainingStintFuel, UpdateSourceTrigger=PropertyChanged}" />

                                    <Border Margin="0,14,0,0"
                                            Padding="14"
                                            Background="#F3E1E4"
                                            CornerRadius="12">
                                        <StackPanel>
                                            <TextBlock Foreground="#2B181B"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding RainCrossoverRecommendation}"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#4A1F24"
                                                       Text="{Binding RainCrossoverSummary}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </TabItem>

                    <TabItem Header="Drivers">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <Border Margin="8" Padding="18" Background="#2A1116" CornerRadius="16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Foreground="#FFF5F5" Text="Drivers" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#D5B3B8"
                                                       Text="Set each driver's pace, time zone, and maximum stint count. This tab uses stacked fields so everything remains visible." />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Padding="14,8"
                                                Background="#7C2430"
                                                Foreground="White"
                                                BorderBrush="#7C2430"
                                                Command="{Binding AddDriverCommand}"
                                                Content="Add Driver" />
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding Drivers}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,12"
                                                        Padding="14"
                                                        Background="#F3E1E4"
                                                        CornerRadius="12">
                                                    <StackPanel>
                                                        <TextBlock Foreground="#4A1F24"
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding Name, TargetNullValue=Driver}" />

                                                        <TextBlock Margin="0,12,0,0" Foreground="#6A3139" Text="Driver Name" />
                                                        <TextBox Margin="0,6,0,0"
                                                                 Padding="8"
                                                                 Background="#FDF5F6"
                                                                 Foreground="#241316"
                                                                 BorderBrush="#7A2E39"
                                                                 Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Margin="0,12,0,0" Foreground="#6A3139" Text="Lap Time" />
                                                        <TextBox Margin="0,6,0,0"
                                                                 Padding="8"
                                                                 Background="#FDF5F6"
                                                                 Foreground="#241316"
                                                                 BorderBrush="#7A2E39"
                                                                 Text="{Binding LapTimeText, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Margin="0,12,0,0" Foreground="#6A3139" Text="VE Per Lap" />
                                                        <TextBox Margin="0,6,0,0"
                                                                 Padding="8"
                                                                 Background="#FDF5F6"
                                                                 Foreground="#241316"
                                                                 BorderBrush="#7A2E39"
                                                                 Text="{Binding EnergyPerLap, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Margin="0,12,0,0" Foreground="#6A3139" Text="Stint Cap" />
                                                        <TextBox Margin="0,6,0,0"
                                                                 Padding="8"
                                                                 Background="#FDF5F6"
                                                                 Foreground="#241316"
                                                                 BorderBrush="#7A2E39"
                                                                 Text="{Binding MaxStints, UpdateSourceTrigger=PropertyChanged}" />

                                                        <TextBlock Margin="0,12,0,0" Foreground="#6A3139" Text="Time Zone" />
                                                        <ComboBox Margin="0,6,0,0"
                                                                  Padding="8"
                                                                  Background="#FDF5F6"
                                                                  Foreground="#241316"
                                                                  BorderBrush="#7A2E39"
                                                                  ItemsSource="{Binding DataContext.TimeZones, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedValuePath="Id"
                                                                  DisplayMemberPath="DisplayName"
                                                                  SelectedValue="{Binding TimeZoneId, UpdateSourceTrigger=PropertyChanged}" />

                                                        <WrapPanel Margin="0,12,0,0">
                                                            <Border Margin="0,0,8,0"
                                                                    Padding="8,4"
                                                                    Background="#F8ECEE"
                                                                    CornerRadius="6">
                                                                <TextBlock Foreground="#4A1F24"
                                                                           Text="{Binding AssignedStints, StringFormat=Assigned stints: {0}}" />
                                                            </Border>
                                                            <Border Margin="0,0,8,0"
                                                                    Padding="8,4"
                                                                    Background="#F8ECEE"
                                                                    CornerRadius="6">
                                                                <TextBlock Foreground="#4A1F24"
                                                                           Text="{Binding MaxStints, StringFormat=Stint cap: {0}}" />
                                                            </Border>
                                                        </WrapPanel>

                                                        <TextBlock Margin="0,10,0,0"
                                                                   Foreground="#6A3139"
                                                                   Text="Lap format: mm:ss.fff. VE per lap is per-driver and controls energy-limited stint length." />

                                                        <Button Margin="0,12,0,0"
                                                                HorizontalAlignment="Left"
                                                                Padding="10,6"
                                                                Background="#8B1E2D"
                                                                Foreground="White"
                                                                BorderBrush="#8B1E2D"
                                                                Command="{Binding DataContext.RemoveDriverCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Content="Remove Driver" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </ScrollViewer>
                    </TabItem>
                </TabControl>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <UniformGrid Grid.Row="0" Columns="2" Margin="0,0,0,16">
                    <Border Margin="0,0,8,0" Padding="18" Background="#4A1820" CornerRadius="16">
                        <StackPanel>
                            <TextBlock Foreground="#FFDDE2" FontSize="15" FontWeight="SemiBold" Text="Plan Summary" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#FFF7F8"
                                       TextWrapping="Wrap"
                                       LineStackingStrategy="BlockLineHeight"
                                       LineHeight="22"
                                       Text="{Binding SummaryText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="8,0,0,0" Padding="18" Background="#F3E1E4" CornerRadius="16">
                        <StackPanel>
                            <TextBlock Foreground="#4A1F24" FontSize="15" FontWeight="SemiBold" Text="Checks" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#2B181B"
                                       TextWrapping="Wrap"
                                       Text="{Binding WarningText}" />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="1" Padding="18" Background="#2A1116" CornerRadius="16">
                    <Border.Resources>
                        <Style x:Key="StintCardStyle" TargetType="Border">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPitStop}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                        <Style x:Key="PitCardStyle" TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsPitStop}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Resources>
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="#FFF5F5" Text="Stint Plan" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="#D5B3B8"
                                           Text="Stints recalculate live from input changes. In live strategy mode, edited stint rows are preserved while timing, tyre usage, and local driver times update immediately."
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Button Grid.Column="1"
                                    VerticalAlignment="Top"
                                    Padding="14,8"
                                    Background="#5C1D24"
                                    Foreground="White"
                                    BorderBrush="#5C1D24"
                                    Command="{Binding RemoveSelectedStintCommand}"
                                    Content="Remove Selected" />
                        </Grid>

                        <ListBox Background="Transparent"
                                 BorderThickness="0"
                                 ItemsSource="{Binding PlanTimelineRows}"
                                 SelectedItem="{Binding SelectedTimelineRow, Mode=TwoWay}">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Outer"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="1"
                                                        CornerRadius="16">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Outer" Property="BorderBrush" Value="#E76F51" />
                                                        <Setter TargetName="Outer" Property="Background" Value="#2F1519" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Border Style="{StaticResource StintCardStyle}"
                                                Padding="12"
                                                Background="{Binding StintCardBackground}"
                                                CornerRadius="14">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Padding="8,3"
                                                        Background="{Binding StintBadgeBackground}"
                                                        CornerRadius="8">
                                                    <TextBlock Foreground="{Binding StintBadgeForeground}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding NumberText, StringFormat=Stint {0}}" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                                    <ComboBox Padding="6"
                                                              Background="#FDF5F6"
                                                              Foreground="#241316"
                                                              BorderBrush="#7A2E39"
                                                              ItemsSource="{Binding AvailableDrivers}"
                                                              SelectedItem="{Binding Driver, UpdateSourceTrigger=PropertyChanged}"
                                                              DisplayMemberPath="Name" />
                                                    <WrapPanel Margin="0,8,0,0">
                                                        <Border Margin="0,0,6,6" Padding="7,3" Background="{Binding StintChipBackground}" CornerRadius="8">
                                                            <TextBlock FontSize="11" Foreground="{Binding StintAccentForeground}" Text="{Binding RaceStartText, StringFormat=Start {0}}" />
                                                        </Border>
                                                        <Border Margin="0,0,6,6" Padding="7,3" Background="{Binding StintChipBackground}" CornerRadius="8">
                                                            <TextBlock FontSize="11" Foreground="{Binding StintAccentForeground}" Text="{Binding RaceEndText, StringFormat=End {0}}" />
                                                        </Border>
                                                        <Border Margin="0,0,6,6" Padding="7,3" Background="{Binding StintChipBackground}" CornerRadius="8">
                                                            <TextBlock FontSize="11" Foreground="{Binding StintAccentForeground}" Text="{Binding DriverLocalText, StringFormat=Local {0}}" />
                                                        </Border>
                                                    </WrapPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Width="96">
                                                    <TextBlock FontSize="11" Foreground="{Binding StintAccentForeground}" Text="Laps" />
                                                    <TextBox Margin="0,4,0,0"
                                                             Padding="6"
                                                             Background="#FDF5F6"
                                                             Foreground="#241316"
                                                             BorderBrush="#7A2E39"
                                                             Text="{Binding Laps, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBlock Margin="0,8,0,0" FontSize="11" Foreground="{Binding StintAccentForeground}" Text="Drive Time" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               Foreground="#241316"
                                                               Text="{Binding MainTimeText}" />
                                                    <TextBlock Margin="0,8,0,0"
                                                               FontSize="11"
                                                               Foreground="{Binding StintAccentForeground}"
                                                               Text="{Binding TyreSetText, StringFormat=Tyre Set {0}}" />
                                                    <CheckBox Margin="0,8,0,0"
                                                              FontSize="11"
                                                              FontWeight="SemiBold"
                                                              Foreground="{Binding StintAccentForeground}"
                                                              IsChecked="{Binding GetQualiTyres, UpdateSourceTrigger=PropertyChanged}"
                                                              Visibility="{Binding IsFirstStint, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                              Content="Get Quali Tyres" />
                                                </StackPanel>

                                                <Border Grid.Row="1"
                                                        Grid.ColumnSpan="3"
                                                        Margin="0,10,0,0"
                                                        Padding="10"
                                                        Background="{Binding StintChipBackground}"
                                                        CornerRadius="12">
                                                    <TextBlock FontSize="12"
                                                               Foreground="{Binding StintAccentForeground}"
                                                               Text="{Binding Notes}"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <Border Style="{StaticResource PitCardStyle}"
                                                Padding="12"
                                                Background="#F3E1E4"
                                                CornerRadius="14">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="1.5*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Padding="8,3"
                                                        Background="#8B1E2D"
                                                        CornerRadius="8">
                                                    <TextBlock Foreground="White"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Text="{Binding NumberText, StringFormat=Pit {0}}" />
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                                    <TextBlock FontSize="11" Foreground="#6A3139" Text="Stop Window" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="#241316"
                                                               Text="{Binding RaceStartText}" />
                                                    <TextBlock FontSize="12" Foreground="#241316" Text="{Binding RaceEndText}" />
                                                    <WrapPanel Margin="0,8,0,0">
                                                        <Border Margin="0,0,6,6" Padding="7,3" Background="#F8ECEE" CornerRadius="8">
                                                            <TextBlock FontSize="11" Foreground="#4A1F24" Text="{Binding PitLaneText, StringFormat=Pit Lane {0}}" />
                                                        </Border>
                                                        <Border Margin="0,0,6,6" Padding="7,3" Background="#F8ECEE" CornerRadius="8">
                                                            <TextBlock FontSize="11" Foreground="#4A1F24" Text="{Binding ServiceText, StringFormat=Service {0}}" />
                                                        </Border>
                                                        <Border Margin="0,0,6,6" Padding="7,3" Background="#F8ECEE" CornerRadius="8">
                                                            <TextBlock FontSize="11" Foreground="#4A1F24" Text="{Binding TotalPitText, StringFormat=Total {0}}" />
                                                        </Border>
                                                    </WrapPanel>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            Width="90"
                                                            Margin="0,0,10,0"
                                                            Visibility="{Binding DataContext.ShowFuelPerLap, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock FontSize="11" Foreground="#6A3139" Text="Fuel Add" />
                                                    <TextBox Margin="0,4,0,0"
                                                             Padding="6"
                                                             Background="#FDF5F6"
                                                             Foreground="#241316"
                                                             BorderBrush="#7A2E39"
                                                             Text="{Binding RefuelAmount, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="3"
                                                            Width="90"
                                                            Margin="0,0,10,0">
                                                    <TextBlock FontSize="11" Foreground="#6A3139" Text="VE Add" />
                                                    <TextBox Margin="0,4,0,0"
                                                             Padding="6"
                                                             Background="#FDF5F6"
                                                             Foreground="#241316"
                                                             BorderBrush="#7A2E39"
                                                             Text="{Binding EnergyAmount, UpdateSourceTrigger=PropertyChanged}">
                                                        <TextBox.Style>
                                                            <Style TargetType="TextBox">
                                                                <Setter Property="IsEnabled" Value="True" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding AutoFillEnergyForNextStint}" Value="True">
                                                                        <Setter Property="IsEnabled" Value="False" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBox.Style>
                                                    </TextBox>
                                                    <CheckBox Margin="0,8,0,0"
                                                              Foreground="#241316"
                                                              FontSize="12"
                                                              FontWeight="SemiBold"
                                                              IsChecked="{Binding AutoFillEnergyForNextStint, UpdateSourceTrigger=PropertyChanged}"
                                                              Content="Add All Needed VE" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="4"
                                                            Width="116">
                                                    <TextBlock FontSize="11" Foreground="#6A3139" Text="Repair (s)" />
                                                    <TextBox Margin="0,4,0,0"
                                                             Padding="6"
                                                             Background="#FDF5F6"
                                                             Foreground="#241316"
                                                             BorderBrush="#7A2E39"
                                                             Text="{Binding RepairSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                                    <CheckBox Margin="0,10,0,0"
                                                              Foreground="#241316"
                                                              FontSize="12"
                                                              FontWeight="SemiBold"
                                                              IsChecked="{Binding ChangeTyres, UpdateSourceTrigger=PropertyChanged}"
                                                              IsEnabled="{Binding CanChangeTyres}"
                                                              Content="Change All Tyres" />
                                                </StackPanel>

                                                <Border Grid.Row="1"
                                                        Grid.ColumnSpan="5"
                                                        Margin="0,10,0,0"
                                                        Padding="10"
                                                        Background="#FDF5F6"
                                                        CornerRadius="12">
                                                    <TextBlock FontSize="12"
                                                               Foreground="#5E2A31"
                                                               Text="{Binding Notes}"
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
