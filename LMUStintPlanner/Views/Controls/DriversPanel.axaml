<UserControl x:Class="LMUStintPlanner.Views.Controls.DriversPanel"
             x:Name="DriversPanelRoot"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="using:LMUStintPlanner.ViewModels"
             x:DataType="viewModels:MainViewModel">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Classes="darkPanel">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Classes="panelKicker" Text="CREW" />
                        <TextBlock Margin="0,2,0,0" Classes="panelTitle" Text="Drivers" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#AFA39A"
                                   TextWrapping="Wrap"
                                   Text="Set each driver's pace, time zone, and maximum stint count. This tab uses stacked fields so everything remains visible." />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Classes="secondaryAction"
                            Command="{Binding AddDriverCommand}"
                            Content="Add Driver" />
                </Grid>

                <ItemsControl ItemsSource="{Binding Drivers}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="viewModels:DriverPlan">
                            <Border Classes="driverCard">
                                <StackPanel>
                                    <StackPanel>
                                        <TextBlock FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="#38BDF8"
                                                   Text="DRIVER" />
                                        <TextBlock Margin="0,2,0,0"
                                                   Foreground="#F8FAFC"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Name}" />
                                    </StackPanel>

                                    <TextBlock Classes="fieldLabel" Text="Driver Name" />
                                    <TextBox Classes="driverInput"
                                             PlaceholderText="Driver name"
                                             Text="{Binding Name}" />

                                    <TextBlock Classes="fieldLabel" Text="Lap Time" />
                                    <TextBox Classes="driverInput"
                                             PlaceholderText="mm:ss.fff"
                                             Text="{Binding LapTimeText}" />

                                    <TextBlock Classes="fieldLabel" Text="VE Per Lap" />
                                    <TextBox Classes="driverInput"
                                             PlaceholderText="Virtual energy used per lap"
                                             Text="{Binding EnergyPerLap}" />

                                    <TextBlock Classes="fieldLabel" Text="Stint Cap" />
                                    <TextBox Classes="driverInput"
                                             PlaceholderText="Maximum stints"
                                             Text="{Binding MaxStints}" />

                                    <TextBlock Classes="fieldLabel" Text="Time Zone" />
                                    <ComboBox Classes="driverInput"
                                              ItemsSource="{Binding #DriversPanelRoot.DataContext.TimeZones}"
                                              SelectedItem="{Binding SelectedTimeZone, Mode=TwoWay}">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Foreground="#F8FAFC"
                                                           Text="{Binding Id}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>

                                    <WrapPanel Margin="0,12,0,0">
                                        <Border Classes="driverChip">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#94A3B8"
                                                           Text="Assigned stints" />
                                                <TextBlock FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F8FAFC"
                                                           Text="{Binding AssignedStints}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Classes="driverChip">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#94A3B8"
                                                           Text="Stint cap" />
                                                <TextBlock FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F8FAFC"
                                                           Text="{Binding MaxStints}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#94A3B8"
                                               TextWrapping="Wrap"
                                               Text="Lap format: mm:ss.fff. VE per lap is per-driver and controls energy-limited stint length." />

                                    <Button Margin="0,12,0,0"
                                            HorizontalAlignment="Left"
                                            Classes="dangerAction"
                                            Command="{Binding #DriversPanelRoot.DataContext.RemoveDriverCommand}"
                                            CommandParameter="{Binding}"
                                            Content="Remove Driver" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
