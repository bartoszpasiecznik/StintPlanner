<UserControl x:Class="LMUStintPlanner.Views.Controls.PitStopTimelineCard"
             x:Name="PitStopCardRoot"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="using:LMUStintPlanner.ViewModels"
             x:DataType="viewModels:PlanTimelineRow">
    <Border Margin="42,3,0,3"
            Padding="8"
            Background="#F4F6F8"
            BorderBrush="#CBD5E1"
            BorderThickness="1"
            CornerRadius="7"
            IsVisible="{Binding IsPitStop}">
        <Grid ColumnDefinitions="36,1.3*,Auto,Auto,Auto,*">
            <Border Width="28"
                    Height="28"
                    Background="#334155"
                    CornerRadius="5">
                <TextBlock HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#F8FAFC"
                           FontSize="11"
                           FontWeight="Bold"
                           Text="{Binding NumberText}" />
            </Border>

            <StackPanel Grid.Column="1" Margin="6,0,10,0">
                <TextBlock FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#64748B"
                           Text="PIT WINDOW" />
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#64748B"
                               Text="Start" />
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#0F172A"
                               Text="{Binding RaceStartText}" />
                    <TextBlock FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#64748B"
                               Text="End" />
                    <TextBlock FontSize="12"
                               Foreground="#475569"
                               Text="{Binding RaceEndText}" />
                </StackPanel>
                <WrapPanel Margin="0,3,0,0">
                    <Border Classes="lightChip">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#334155" Text="Lane" />
                            <TextBlock FontSize="10" Foreground="#334155" Text="{Binding PitLaneText}" />
                        </StackPanel>
                    </Border>
                    <Border Classes="lightChip">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#334155" Text="Service" />
                            <TextBlock FontSize="10" Foreground="#334155" Text="{Binding ServiceText}" />
                        </StackPanel>
                    </Border>
                    <Border Classes="lightChip">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#334155" Text="Total" />
                            <TextBlock FontSize="10" Foreground="#334155" Text="{Binding TotalPitText}" />
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </StackPanel>

            <StackPanel Grid.Column="2"
                        Width="74"
                        Margin="0,0,8,0"
                        IsVisible="{Binding #PitStopCardRoot.ShowFuelPerLap}">
                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#64748B" Text="Fuel" />
                <TextBox Classes="compactInput"
                         MinHeight="26"
                         Padding="5,3"
                         Text="{Binding RefuelAmount}" />
            </StackPanel>

            <StackPanel Grid.Column="3"
                        Width="78"
                        Margin="0,0,8,0">
                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#64748B" Text="VE" />
                <TextBox Classes="compactInput"
                         MinHeight="26"
                         Padding="5,3"
                         Text="{Binding EnergyAmount}"
                         IsEnabled="{Binding IsEnergyInputEnabled}" />
                <CheckBox Classes="pitToggle"
                          Margin="0,4,0,0"
                          FontSize="10"
                          FontWeight="SemiBold"
                          IsChecked="{Binding AutoFillEnergyForNextStint}"
                          Content="Auto" />
            </StackPanel>

            <StackPanel Grid.Column="4" Width="96">
                <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#64748B" Text="Repair" />
                <TextBox Classes="compactInput"
                         MinHeight="26"
                         Padding="5,3"
                         Text="{Binding RepairSeconds}" />
                <CheckBox Classes="pitToggle"
                          Margin="0,4,0,0"
                          FontSize="10"
                          FontWeight="SemiBold"
                          IsChecked="{Binding ChangeTyres}"
                          IsEnabled="{Binding CanChangeTyres}"
                          Content="Tyres" />
            </StackPanel>

            <TextBlock Grid.Column="5"
                       Margin="10,16,0,0"
                       FontSize="11"
                       Foreground="#64748B"
                       Text="{Binding Notes, StringFormat='Notes: {0}'}"
                       TextWrapping="Wrap" />
        </Grid>
    </Border>
</UserControl>
