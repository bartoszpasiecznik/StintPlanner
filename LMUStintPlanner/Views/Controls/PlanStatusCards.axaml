<UserControl x:Class="LMUStintPlanner.Views.Controls.PlanStatusCards"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="using:LMUStintPlanner.ViewModels"
             x:DataType="viewModels:MainViewModel">
    <Grid Margin="0,0,0,12" ColumnDefinitions="1.25*,*">
        <Border Margin="0,0,6,0"
                Padding="14"
                Background="#171210"
                BorderBrush="#312620"
                BorderThickness="1"
                CornerRadius="8">
            <Grid ColumnDefinitions="Auto,*">
                <Border Width="34"
                        Height="34"
                        Background="#251B18"
                        BorderBrush="#4A3931"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#F08A4B"
                               Text="Σ" />
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Classes="panelKicker" Text="PLAN STATE" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#F7EFE7"
                               TextWrapping="Wrap"
                               Text="{Binding SummaryText}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Margin="6,0,0,0"
                Padding="14"
                Background="#EDE2D8"
                BorderBrush="#CBB9AC"
                BorderThickness="1"
                CornerRadius="8">
            <Grid ColumnDefinitions="Auto,*">
                <Border Width="34"
                        Height="34"
                        Background="#FBF4ED"
                        BorderBrush="#D9C8BC"
                        BorderThickness="1"
                        CornerRadius="6">
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#8F3B27"
                               Text="!" />
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#8F3B27"
                               Text="CHECKS" />
                    <TextBlock Margin="0,3,0,0"
                               Foreground="#211A17"
                               TextWrapping="Wrap"
                               Text="{Binding WarningText}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
